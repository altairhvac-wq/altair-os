# Supabase (required for backend integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Enable alpha hardening behaviors locally (also on by default in production)
# NEXT_PUBLIC_ALPHA_HARDENING=true

# In-app beta bug reporter (on by default). Set to false after beta ends.
# NEXT_PUBLIC_SHOW_BETA_BUG_REPORT_BUTTON=false

# Optional: service role for server-only admin tasks (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Team invite email (Resend). Invites still save without these; UI reports delivery honestly.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Public app URL used in invite and estimate approval emails.
# Use a full URL with https:// (for example, https://your-app.vercel.app).
# On Vercel, falls back to https://VERCEL_URL when unset.
NEXT_PUBLIC_APP_URL=

# Optional local dev only: redirect billing emails (estimates/invoices) away from customers.
# Never set in production Vercel — removes real customer delivery for beta.
# EMAIL_RECIPIENT_OVERRIDE=you@example.com

# SMS (server-only — not active yet; foundation placeholders only)
# SMS_PROVIDER=disabled
# SMS_FROM_NUMBER=

# Stripe webhooks (server-only — never expose to the browser)
STRIPE_WEBHOOK_SECRET=

# Stripe Connect (server-only — never expose to the browser)
STRIPE_SECRET_KEY=

# AI Assist (OpenAI, server-only — never expose keys to the browser)
OPENAI_API_KEY=
# Optional model override; defaults to gpt-4o-mini server-side when unset.
AI_MODEL=
# Disabled by default. Set to true to enable server-side draft generation.
AI_FEATURES_ENABLED=false
