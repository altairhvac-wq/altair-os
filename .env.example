# Supabase (required for backend integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Enable alpha hardening behaviors locally (also on by default in production)
# NEXT_PUBLIC_ALPHA_HARDENING=true

# Optional: service role for server-only admin tasks (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Team invite email (Resend). Invites still save without these; UI reports delivery honestly.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Public app URL used in invite emails (falls back to https://VERCEL_URL on Vercel)
NEXT_PUBLIC_APP_URL=
